{
	"name": "mcp-sqlite-tools-plus",
	"version": "0.2.0",
	"description": "MCP server for local SQLite: CRUD, schema, relations, generated columns, and multi-format import/export (CSV, JSON, XLSX). Fork of mcp-sqlite-tools.",
	"keywords": [
		"ai",
		"agent",
		"csv",
		"database",
		"excel",
		"json",
		"llm",
		"local-database",
		"mcp",
		"model-context-protocol",
		"sql",
		"sqlite",
		"sqlite3",
		"xlsx"
	],
	"license": "MIT",
	"author": "MauricioPerera",
	"contributors": [
		"Scott Spence (original author of mcp-sqlite-tools)"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MauricioPerera/mcp-sqlite-tools-plus.git"
	},
	"homepage": "https://github.com/MauricioPerera/mcp-sqlite-tools-plus#readme",
	"bugs": {
		"url": "https://github.com/MauricioPerera/mcp-sqlite-tools-plus/issues"
	},
	"bin": {
		"mcp-sqlite-tools-plus": "./dist/index.js"
	},
	"files": [
		"dist",
		"package.json",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"build": "vp pack",
		"start": "node dist/index.js",
		"dev": "vp pack --watch",
		"inspect": "npx @modelcontextprotocol/inspector dist/index.js",
		"clean": "rm -rf dist",
		"check": "vp check",
		"test": "vp test",
		"format": "vp check --fix",
		"format:check": "vp check",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm run build && changeset publish",
		"publish-mcp": "pnpm run sync-server-json && mcp-publisher publish",
		"sync-server-json": "node -e \"const pkg = require('./package.json'); const server = require('./server.json'); server.version = pkg.version; server.packages[0].version = pkg.version; require('fs').writeFileSync('./server.json', JSON.stringify(server, null, 2));\""
	},
	"dependencies": {
		"@remix-run/node-fetch-server": "^0.13.3",
		"@tmcp/adapter-valibot": "^0.1.6",
		"@tmcp/transport-http": "^0.8.6",
		"@tmcp/transport-stdio": "^0.4.3",
		"better-sqlite3": "^12.10.0",
		"csv-parser": "^3.2.1",
		"csv-writer": "^1.6.0",
		"exceljs": "^4.4.0",
		"tmcp": "^1.19.4",
		"valibot": "^1.4.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.9.1",
		"vite-plus": "^0.1.22",
		"vitest": "^4.1.7"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "pnpm@11.8.0",
	"mcpName": "io.github.mauricioperera/mcp-sqlite-tools-plus"
}
